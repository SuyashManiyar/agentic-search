# Copy to .env and fill in. Never commit .env or real keys.

# Groq LLM — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
# If you hit 413 / TPM errors, lower further (default 8000).
GROQ_MAX_PROMPT_CHARS=8000

# Parallel Search (required) — https://docs.parallel.ai/search/search-quickstart
PARALLEL_API_KEY=
PARALLEL_BETA_HEADER=search-extract-2025-10-10
PARALLEL_MAX_CHARS_PER_RESULT=3500
